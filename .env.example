# Aplicação
APP_NAME=Inteligência Auto Postos
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL (banco próprio da aplicação)
POSTGRES_USER=smartfuel
POSTGRES_PASSWORD=smartfuel
POSTGRES_DB=smartfuel
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://smartfuel:smartfuel@localhost:5432/smartfuel
DATABASE_URL_SYNC=postgresql+psycopg://smartfuel:smartfuel@localhost:5432/smartfuel

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smartfuel
MINIO_SECURE=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Backend / Frontend ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8000

# XPERT ATX / SQL Server (somente leitura — Sprint 5+)
# Não use a conta sa. Crie um usuário read-only por instância.
XPERT_SQLSERVER_HOST=
XPERT_SQLSERVER_PORT=1433
XPERT_SQLSERVER_DATABASE=atxdados
XPERT_SQLSERVER_USER=
XPERT_SQLSERVER_PASSWORD=
XPERT_SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
