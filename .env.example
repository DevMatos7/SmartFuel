# Aplicação
APP_NAME=Inteligência Auto Postos
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Backend / Frontend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_VERSION=0.1.0

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL (banco próprio da aplicação)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=smartfuel
POSTGRES_USER=smartfuel
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://smartfuel:change_me@localhost:5432/smartfuel
DATABASE_URL_SYNC=postgresql+psycopg://smartfuel:change_me@localhost:5432/smartfuel

# Redis (persistência desativada nesta etapa — ver docs)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=evidences
MINIO_SECURE=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Cotações — Sprint 3 / 3.1
MINIO_QUOTE_EVIDENCE_BUCKET=quote-evidences
QUOTE_EVIDENCE_MAX_SIZE_MB=10
QUOTE_AI_MAX_FILE_SIZE_MB=10
QUOTE_AI_MAX_BATCH_FILES=20
QUOTE_AI_MAX_BATCH_SIZE_MB=50
QUOTE_AI_MAX_PDF_PAGES=20
QUOTE_AI_MAX_IMAGE_PIXELS=40000000
QUOTE_EXPIRATION_INTERVAL_MINUTES=15
QUOTE_EXPIRATION_BATCH_SIZE=500
QUOTE_EXPIRATION_LOCK_TIMEOUT_SECONDS=300
QUOTE_DUPLICATE_WARNING_WINDOW_MINUTES=60
SIGNED_URL_EXPIRE_SECONDS=300
OBJECT_STORAGE_ALLOW_MEMORY_FALLBACK=false

# XPERT ATX / SQL Server (somente leitura — Sprint 5+)
# Não use a conta sa. Crie um usuário read-only por instância.
XPERT_SQLSERVER_HOST=
XPERT_SQLSERVER_PORT=1433
XPERT_SQLSERVER_DATABASE=
XPERT_SQLSERVER_USER=
XPERT_SQLSERVER_PASSWORD=
XPERT_SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
XPERT_SQLSERVER_ENCRYPT=true
# Homologação: defina no .env local (nunca commitar senha).
# XPERT_ALLOW_UNSAFE_PRIVILEGES=true somente se a conta for elevada (ex.: sa em lab).
XPERT_ALLOW_UNSAFE_PRIVILEGES=false

# Autenticação — Sprint 1
JWT_SECRET_KEY=change_me_use_long_random_secret_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
PASSWORD_MIN_LENGTH=8
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_SECONDS=60
LOGIN_RATE_ALLOW_MEMORY_FALLBACK=true

# Cadastros mestres — Sprint 2
DEFAULT_SUPPLIER_ALLOWED=false
DEFAULT_MINIMUM_VOLUME_LITERS=5000.000
MASTER_DATA_IMPORT_MAX_BYTES=5242880

# Testes — banco PostgreSQL exclusivo (obrigatório para pytest)
TEST_DATABASE_URL=postgresql+asyncpg://smartfuel_test:smartfuel_test@localhost:5433/smartfuel_test
TEST_DATABASE_URL_SYNC=postgresql+psycopg://smartfuel_test:smartfuel_test@localhost:5433/smartfuel_test
